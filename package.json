{
  "name": "zsms_ai_docread",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2.7.0",
    "@google/genai": "^2.0.1",
    "@sap/cds": "^9.8.4",
    "@sap/hdi-deploy": "^5.6.1",
    "axios": "^1.16.0",
    "dotenv": "^17.4.2",
    "express": "^4",
    "form-data": "^4.0.5",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-zsms_docread": "cds watch --open zsmsdocread/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy zsms_ai_docread --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {},
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/zsms_docread"
  ]
}
