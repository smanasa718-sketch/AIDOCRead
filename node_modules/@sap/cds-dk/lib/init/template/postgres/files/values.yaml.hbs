---
srv:
  bindings:
    postgres:
      serviceInstanceName: postgres
postgres-db-deployer:
  image:
    repository: {{appName}}-postgres-deployer
  bindings:
    postgres:
      serviceInstanceName: postgres
  resources:
    limits:
      cpu: 2000m
      memory: 1G
    requests:
      cpu: 1000m
      memory: 1G
postgres:
  serviceOfferingName: postgresql-db
  servicePlanName: standard
  parameters:
    allow_access: "{{KYMA_GATEWAY_IP}}"
